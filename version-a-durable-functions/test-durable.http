@baseUrl = http://localhost:7071/api

### Scenario 1 - Auto-approve expense under $100
POST {{baseUrl}}/start-expense
Content-Type: application/json

{
  "employee_name": "Nina Patel",
  "employee_email": "nina.patel@contoso-demo.com",
  "amount": 64,
  "category": "supplies",
  "description": "Office stationery for project meeting",
  "manager_email": "oliver.grant@contoso-demo.com"
}

###

### Scenario 2 - Manager approval required, then approve
POST {{baseUrl}}/start-expense
Content-Type: application/json

{
  "employee_name": "Marcus Chen",
  "employee_email": "marcus.chen@contoso-demo.com",
  "amount": 245,
  "category": "software",
  "description": "Monthly design tool subscription renewal",
  "manager_email": "oliver.grant@contoso-demo.com"
}

###

### Scenario 3 - Manager approval required, then reject
POST {{baseUrl}}/start-expense
Content-Type: application/json

{
  "employee_name": "Sofia Ramirez",
  "employee_email": "sofia.ramirez@contoso-demo.com",
  "amount": 420,
  "category": "equipment",
  "description": "Request for a second office monitor",
  "manager_email": "oliver.grant@contoso-demo.com"
}

###

### Scenario 4 - No manager response, request times out and escalates
POST {{baseUrl}}/start-expense
Content-Type: application/json

{
  "employee_name": "Jordan Blake",
  "employee_email": "jordan.blake@contoso-demo.com",
  "amount": 180,
  "category": "travel",
  "description": "Train ticket for client visit in Toronto",
  "manager_email": "oliver.grant@contoso-demo.com"
}

###

### Scenario 5 - Missing required field
POST {{baseUrl}}/start-expense
Content-Type: application/json

{
  "employee_name": "Leah Morris",
  "employee_email": "leah.morris@contoso-demo.com",
  "amount": 130,
  "category": "meals",
  "description": "Dinner with external project partner"
}

###

### Scenario 6 - Invalid category
POST {{baseUrl}}/start-expense
Content-Type: application/json

{
  "employee_name": "Ethan Walker",
  "employee_email": "ethan.walker@contoso-demo.com",
  "amount": 155,
  "category": "entertainment",
  "description": "Team movie night reimbursement",
  "manager_email": "oliver.grant@contoso-demo.com"
}

###

### Manager approves
### Replace the instance_id below with the ID returned by Scenario 2
POST {{baseUrl}}/manager-decision
Content-Type: application/json

{
  "instance_id": "PASTE_SCENARIO_2_INSTANCE_ID_HERE",
  "decision": "approved"
}

###

### Manager rejects
### Replace the instance_id below with the ID returned by Scenario 3
POST {{baseUrl}}/manager-decision
Content-Type: application/json

{
  "instance_id": "PASTE_SCENARIO_3_INSTANCE_ID_HERE",
  "decision": "rejected"
}